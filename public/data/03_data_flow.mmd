flowchart LR
    %% Flask Data Flow - Auto-generated from architecture analysis %%
    %% 16 nodes, 8 subgraphs, error branch, U-shape layout %%

    subgraph Input["Input / 入力"]
        Client["[User] Client<br/>Browser"]
    end

    subgraph Entry["Entry / エントリポイント"]
        WSGICall["[Entry] WSGI Call<br/>Flask.__call__()"]
        Middleware["[Hook] Middleware<br/>WSGIミドルウェア"]
    end

    subgraph Context["Context / コンテキスト"]
        PushCtx["[Ctx] AppContext Push<br/>ctx stack"]
        BindReq["[Hook] Bind Request<br/>LocalProxy"]
    end

    subgraph Processing["Processing / 処理"]
        BeforeReq["[Hook] before_request<br/>前処理フック"]
        URLMatch["[Router] URL Router<br/>url_map.match()"]
    end

    subgraph View["View / ビュー"]
        ViewFunc["[View] View Function<br/>ビジネスロジック"]
        Template["[View] Template<br/>Jinja2 Render"]
    end

    subgraph Error["Error / エラー"]
        ErrorHandler["[Error] Error Handler<br/>例外ハンドラ"]
    end

    subgraph Response["Response / レスポンス"]
        MakeRes["[Resp] Response Build<br/>Response構築"]
        AfterReq["[Hook] after_request<br/>後処理フック"]
    end

    subgraph Cleanup["Cleanup / クリーンアップ"]
        SessionSave["[Session] Session Save<br/>Cookie保存"]
        Teardown["[Cleanup] teardown<br/>リソース解放"]
        PopCtx["[Ctx] Context Pop<br/>ctx解放"]
    end

    subgraph Output["Output / 出力"]
        HTTPResp["[Output] HTTP Response<br/>200 OK"]
    end

    Client -->|HTTP Request| WSGICall
    WSGICall -->|WSGI Environ| Middleware
    Middleware -->|Request Init| PushCtx
    PushCtx -->|Context Push| BindReq
    BindReq -->|Hook Chain| BeforeReq
    BeforeReq -->|Route Dispatch| URLMatch
    URLMatch -->|Matched Route| ViewFunc
    ViewFunc -->|Render Context| Template
    ViewFunc -->|Exception| ErrorHandler
    Template -->|HTML| MakeRes
    ErrorHandler -->|Error Response| MakeRes
    MakeRes -->|Response Obj| AfterReq
    AfterReq -->|Session Data| SessionSave
    SessionSave -->|Cleanup Signal| Teardown
    Teardown -->|Context Release| PopCtx
    PopCtx -->|HTTP Response| HTTPResp

